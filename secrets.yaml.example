# secrets.yaml.example
#
# The API encryption key and Wi-Fi credentials are NO LONGER stored here.
#
# API key  — auto-generated per device at first boot (see m5dial_security.h).
#            Copy it from the "Setup Key" entity in HA or from the device web page.
#
# Wi-Fi    — provisioned at runtime via improv_serial (USB, browser-based)
#            or the "Sonos Dial Setup" captive-portal hotspot.
#
# The only credential you may want to set is the OTA update password.
# If you leave it as the default below, anyone on your network can push firmware.

ota_password: "your_ota_password"
